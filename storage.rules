rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasStoredRole(role) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.systemRole == role;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true
        || request.auth.token.role == 'admin'
        || request.auth.token.role == 'superadmin'
        || request.auth.token.email == 'renato.fabbri@gmail.com'
        || hasStoredRole('admin')
        || hasStoredRole('superadmin')
      );
    }

    function isAllowedDocument() {
      return request.resource != null
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/jpeg|image/png');
    }

    function ownsPendingEuropeanGatheringRegistration(registrationId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/europeanGatheringRegistrations/$(registrationId))
        && firestore.get(/databases/(default)/documents/europeanGatheringRegistrations/$(registrationId)).data.userId == request.auth.uid
        && firestore.get(/databases/(default)/documents/europeanGatheringRegistrations/$(registrationId)).data.status == 'pending';
    }

    match /europeanGatheringRegistrations/{registrationId}/{fileName} {
      allow read: if isAdmin() || isSignedIn();
      allow create: if isSignedIn()
        && isAllowedDocument()
        && fileName.matches('(identityDocument|paymentProof|consentDocument)-.*');
      allow delete: if isAdmin() || ownsPendingEuropeanGatheringRegistration(registrationId);
      allow update: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
